{
  "info": {
    "name": "Gestor Bancario API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3006"
    },
    {
      "key": "accountIdOrigen",
      "value": ""
    },
    {
      "key": "accountIdDestino",
      "value": ""
    },
    {
      "key": "transactionId",
      "value": ""
    },
    {
      "key": "favoriteId",
      "value": ""
    },
    {
      "key": "usuarioId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Accounts - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tipoCuenta\": \"AHORRO\",\n  \"saldo\": 2500,\n  \"moneda\": \"USD\"\n}"
        },
        "url": "{{baseUrl}}/gestionBancaria/api/v1/account/create"
      }
    },
    {
      "name": "Accounts - Listar",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/gestionBancaria/api/v1/account/get?page=1&limit=10&estado=true"
      }
    },
    {
      "name": "Transactions - Crear Transferencia",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tipoTransaccion\": \"TRANSFERENCIA\",\n  \"monto\": 100,\n  \"moneda\": \"EUR\",\n  \"descripcion\": \"Transferencia de prueba\",\n  \"cuentaOrigen\": \"{{accountIdOrigen}}\",\n  \"cuentaDestino\": \"{{accountIdDestino}}\"\n}"
        },
        "url": "{{baseUrl}}/gestionBancaria/api/v1/transactions/create"
      }
    },
    {
      "name": "Transactions - Actualizar",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"estado\": \"CANCELADA\",\n  \"descripcion\": \"Cancelada en prueba\"\n}"
        },
        "url": "{{baseUrl}}/gestionBancaria/api/v1/transactions/update/{{transactionId}}"
      }
    },
    {
      "name": "Transactions - Listar",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/gestionBancaria/api/v1/transactions/get?page=1&limit=10"
      }
    },
    {
      "name": "Transactions - Buscar por ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/gestionBancaria/api/v1/transactions/get/{{transactionId}}"
      }
    },
    {
      "name": "Favorites - Agregar",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuario\": \"{{usuarioId}}\",\n  \"cuenta\": \"{{accountIdDestino}}\",\n  \"tipo\": \"AHORRO\",\n  \"alias\": \"Cuenta favorita\"\n}"
        },
        "url": "{{baseUrl}}/gestionBancaria/api/v1/favorites"
      }
    },
    {
      "name": "Favorites - Listar",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/gestionBancaria/api/v1/favorites?usuario={{usuarioId}}"
      }
    },
    {
      "name": "Favorites - Eliminar",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/gestionBancaria/api/v1/favorites/{{favoriteId}}?usuario={{usuarioId}}"
      }
    },
    {
      "name": "Favorites - Transferencia Rapida",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuario\": \"{{usuarioId}}\",\n  \"monto\": 50,\n  \"moneda\": \"USD\",\n  \"descripcion\": \"Transferencia rapida de prueba\"\n}"
        },
        "url": "{{baseUrl}}/gestionBancaria/api/v1/favorites/{{favoriteId}}/transfer"
      }
    }
  ]
}
